function submitCode() {
    // Get the text from the user input and make it lowercase
    const input = document.getElementById("computerInput").value.toLowerCase().trim();
    const monitorDisplay = document.getElementById("monitorScreen");

    switch(input) {
        case "dipper":
            monitorDisplay.innerHTML = "<img src='dipper_note.png' />";
            break;
        case "riddle":
            monitorDisplay.innerHTML = "<p>What has a key but no lock?</p>";
            // Code to trigger a multi-step riddle sequence
            break;
        case "secret_video":
            monitorDisplay.innerHTML = "<video src='hidden_lore.mp4' autoplay></video>";
            break;
        default:
            monitorDisplay.innerHTML = "<p>ERROR: INVALID CODE</p>";
    }
}
